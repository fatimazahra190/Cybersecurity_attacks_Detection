# ── CyberSec Lambda — Local Development Environment ─────────────────
# Copy this file: cp .env.local .env
# Then run: docker compose up -d

# ── Hadoop ────────────────────────────────────────────────────────────
HADOOP_NAMENODE=namenode
HDFS_PORT=9000

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:29092

# ── HBase ─────────────────────────────────────────────────────────────
HBASE_HOST=hbase
HBASE_PORT=9090
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# ── Cassandra ─────────────────────────────────────────────────────────
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
CASSANDRA_DC=datacenter1

# ── API ───────────────────────────────────────────────────────────────
SERVER_PORT=8080
